apiVersion: v1
kind: Namespace
metadata:
  name: {{NAMESPACE}}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{APP_NAME}}-config
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
data:
  config.yaml: |
    server:
      addr: ":12224"
      mode: "release"

    log:
      level: "info"
      format: "json"
      log_body: true
      max_body_size: 8192

    auth:
      enabled: {{AUTH_ENABLED}}
      header: "Authorization"
      tokens:
        - "{{AUTH_TOKEN}}"

    upstream:
      base_url: "{{UPSTREAM_BASE_URL}}"
      timeout: "10m"
      api_key: ""
      forward_client_authorization: false

    transform:
      enabled: true
      inject_think_tag: true
      strip_reasoning_fields: true
      parse_think_from_content: true
      reasoning_fields:
        - reasoning_content
        - reasoning
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{APP_NAME}}
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
spec:
  replicas: {{REPLICAS}}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{APP_NAME}}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{APP_NAME}}
        app.kubernetes.io/component: gateway
    spec:
      containers:
        - name: sbgw
          image: {{IMAGE}}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 12224
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
          volumeMounts:
            - name: config
              mountPath: /app/config.yaml
              subPath: config.yaml
      volumes:
        - name: config
          configMap:
            name: {{APP_NAME}}-config
---
apiVersion: v1
kind: Service
metadata:
  name: {{APP_NAME}}
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
spec:
  type: {{SERVICE_TYPE}}
  selector:
    app.kubernetes.io/name: {{APP_NAME}}
  ports:
    - name: http
      port: 12224
      targetPort: http
      {{NODE_PORT_LINE}}
