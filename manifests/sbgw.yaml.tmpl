apiVersion: v1
kind: Namespace
metadata:
  name: {{NAMESPACE}}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{APP_NAME}}-config
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
data:
  config.yaml: |
    server:
      addr: ":12224"
      mode: "release"

    log:
      level: "info"
      format: "json"
      log_body: true
      log_headers: false
      max_body_size: 8192
      redact_headers:
        - authorization
        - x-api-key
        - api-key

    auth:
      enabled: {{AUTH_ENABLED}}
      header: "Authorization"
      tokens:{{AUTH_TOKENS_BLOCK}}
      keys:{{AUTH_KEYS_BLOCK}}

    upstream:
      base_url: "{{UPSTREAM_BASE_URL}}"
      timeout: "10m"
      api_key: "{{UPSTREAM_API_KEY}}"
      forward_client_authorization: {{UPSTREAM_FORWARD_CLIENT_AUTHORIZATION}}
      strategy: "{{UPSTREAM_STRATEGY}}"
      model_map:
        qwen3.6: "qwen3.6-27b-w8a8"
        qwen3.5: "qwen3.5-32b-w8a8"
      routes:
        - name: "qwen36-think"
          path: "/qwen36-think"
          model: "qwen3.6-thinking"
          upstream_model: "qwen3.6-27b-w8a8"
          upstream_path: "/v1/chat/completions"
          endpoints: ["default"]
          request_patches:
            - op: set
              path: "chat_template_kwargs.enable_thinking"
              value: true
        - name: "qwen36-direct"
          path: "/qwen36-direct"
          model: "qwen3.6-direct"
          upstream_model: "qwen3.6-27b-w8a8"
          upstream_path: "/v1/chat/completions"
          endpoints: ["default"]
          request_patches:
            - op: set
              path: "chat_template_kwargs.enable_thinking"
              value: false
        - name: "qwen35-think"
          path: "/qwen35-think"
          model: "qwen3.5-thinking"
          upstream_model: "qwen3.5-32b-w8a8"
          upstream_path: "/v1/chat/completions"
          endpoints: ["default"]
          request_patches:
            - op: set
              path: "chat_template_kwargs.enable_thinking"
              value: true
        - name: "qwen35-direct"
          path: "/qwen35-direct"
          model: "qwen3.5-direct"
          upstream_model: "qwen3.5-32b-w8a8"
          upstream_path: "/v1/chat/completions"
          endpoints: ["default"]
          request_patches:
            - op: set
              path: "chat_template_kwargs.enable_thinking"
              value: false
      endpoints:
        - name: "default"
          base_url: "{{UPSTREAM_BASE_URL}}"
          api_key: "{{UPSTREAM_API_KEY}}"
          weight: 1
          timeout: "10m"
          models: []

    transform:
      enabled: true
      inject_think_tag: true
      strip_reasoning_fields: true
      parse_think_from_content: true
      reorder_system_messages: true
      reasoning_fields:
        - reasoning_content
        - reasoning
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{APP_NAME}}
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
spec:
  replicas: {{REPLICAS}}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{APP_NAME}}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{APP_NAME}}
        app.kubernetes.io/component: gateway
    spec:
      containers:
        - name: sbgw
          image: {{IMAGE}}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 12224
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
          volumeMounts:
            - name: config
              mountPath: /app/config.yaml
              subPath: config.yaml
      volumes:
        - name: config
          configMap:
            name: {{APP_NAME}}-config
---
apiVersion: v1
kind: Service
metadata:
  name: {{APP_NAME}}
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: {{APP_NAME}}
    app.kubernetes.io/component: gateway
spec:
  type: {{SERVICE_TYPE}}
  selector:
    app.kubernetes.io/name: {{APP_NAME}}
  ports:
    - name: http
      port: 12224
      targetPort: http
      {{NODE_PORT_LINE}}
